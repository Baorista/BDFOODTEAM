<?xml version="1.0" encoding="utf-8"?>
<!-- item_selected_image.xml - Ảnh thu nhỏ đã chọn trong form đánh giá -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="80dp"
    android:layout_height="80dp"
    android:layout_marginEnd="8dp">

    <ImageView
        android:id="@+id/imgSelected"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_rounded_8dp"
        android:clipToOutline="true"
        android:scaleType="centerCrop" />

    <!-- Play icon overlay ở giữa (chỉ hiện cho video) -->
    <ImageView
        android:id="@+id/imgPlayIcon"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_play"
        android:visibility="gone" />

    <!-- Nút X xóa ảnh - góc trên phải -->
    <ImageButton
        android:id="@+id/btnRemoveImage"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_gravity="top|end"
        android:layout_margin="2dp"
        android:background="@drawable/bg_circle_dark"
        android:contentDescription="Xóa ảnh"
        android:padding="4dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_close"
        android:tint="@android:color/white" />

</FrameLayout>
