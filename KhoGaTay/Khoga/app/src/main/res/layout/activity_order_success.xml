<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">

<!--        <LinearLayout-->
<!--            android:id="@+id/btnBack"-->
<!--            android:layout_width="wrap_content"-->
<!--            android:layout_height="match_parent"-->
<!--            android:clickable="true"-->
<!--            android:focusable="true"-->
<!--            android:background="?attr/selectableItemBackground"-->
<!--            android:gravity="center_vertical"-->
<!--            android:orientation="horizontal"-->
<!--            android:paddingEnd="16dp">-->

<!--            <ImageView-->
<!--                android:layout_width="20dp"-->
<!--                android:layout_height="20dp"-->
<!--                android:src="@drawable/ic_back"-->
<!--                app:tint="#333333" />-->
<!--        </LinearLayout>-->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Đặt hàng thành công"
            android:textColor="#333333"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/layoutBottomButtons"
        android:layout_below="@+id/layoutHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bạn đã đặt đơn hàng thành công"
                android:textColor="#5A4B75"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cảm ơn vì đã đặt đơn hàng. Chúng tôi sẽ gửi tracking đơn hàng ngay khi gửi ship."
                android:textColor="#666666"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/tvOrderId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Order #3004175"
                android:textColor="#5A4B75"
                android:textSize="18sp"
                android:layout_marginBottom="40dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Địa chỉ giao hàng"
                android:textColor="#5A4B75"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tvSuccessName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Họ và tên: Nguyễn Kim Bảo"
                android:textColor="#333333"
                android:textSize="15sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvSuccessPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Số điện thoại: 0363636367"
                android:textColor="#333333"
                android:textSize="15sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvSuccessAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Địa chỉ chi tiết: Summoner's Rift"
                android:textColor="#333333"
                android:textSize="15sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvExpectedDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ngày dự kiến giao: 28/2 - 29/2"
                android:textColor="#5A4B75"
                android:textSize="16sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutBottomButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingBottom="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMyOrders"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:backgroundTint="#5A4B75"
            android:text="Đơn mua"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:cornerRadius="27dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHome"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:backgroundTint="#5A4B75"
            android:text="Trang chủ"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:cornerRadius="27dp" />
    </LinearLayout>

</RelativeLayout>